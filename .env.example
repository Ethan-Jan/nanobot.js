# 本地环境变量（可选）
# 复制本文件为同目录下的 `.env` 后填写；`.env` 勿提交 Git（已列入 .gitignore）
#
# 以下键名与 openai-compat / status 等一致，按需取消注释：

# MOONSHOT_API_KEY=
# KIMI_API_KEY=
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# ZHIPUAI_API_KEY=
# ZHIPU_API_KEY=
# BIGMODEL_API_KEY=

# 显式指定默认 provider + 密钥（与 nanobot.config.json 中 agents.defaults.provider 对应）
# NANOBOT_PROVIDER=moonshot
# NANOBOT_API_KEY=

# NANOBOT_CONFIG=
# NANOBOT_WORKSPACE=

# NANOBOT_WEIXIN_VERBOSE=0
# NANOBOT_API_DEV=0
# ADMIN_PORT=18791
