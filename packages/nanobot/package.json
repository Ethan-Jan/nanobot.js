{
  "name": "nanobot",
  "version": "0.1.0",
  "description": "Ultra-light TypeScript personal AI assistant (OpenAI-compatible providers)",
  "type": "module",
  "bin": {
    "nanobot": "./dist/cli.js"
  },
  "scripts": {
    "build": "vite build",
    "build:watch": "vite build --watch",
    "start": "node dist/cli.js",
    "start:dev": "vite-node --watch src/cli.ts",
    "start:reload": "node scripts/reload-dist.mjs",
    "dev": "vite-node --watch src/cli.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "openai": "^4.80.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/qrcode": "^1.5.5",
    "typescript": "^5.7.0",
    "vite": "^8.0.0",
    "vite-node": "^6.0.0"
  }
}
