{
  "name": "@nanobot/admin",
  "version": "0.1.0",
  "private": true,
  "description": "B-side admin: config + status over HTTP (Ant Design)",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "concurrently -k -n api,ui -c blue,green \"pnpm --filter @nanobot/api start:dev\" \"wait-on -t 120000 http://127.0.0.1:18791/api/health && vite\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "antd": "^6.3.5",
    "dayjs": "^1.11.13",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/runtime": "^7.27.0",
    "@rolldown/plugin-babel": "^0.2.2",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.0",
    "wait-on": "^8.0.1",
    "vite-node": "^6.0.0"
  }
}
